rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isRole(value) {
      return value in ['admin', 'player'];
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && currentUserDoc().exists()
        && currentUserDoc().data.role == 'admin';
    }

    function isValidDateKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isTimestampOrIsoString(value) {
      return value is timestamp
        || (value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}T.*$'));
    }

    function validCommentOrMissing(data) {
      return !('comment' in data)
        || (data.comment is string && data.comment.size() >= 50);
    }

    // =====================
    // Public read game data
    // =====================
    match /dailyMissions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /storyEpisodes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gameConfig/rules {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ato (seasons) - necessário para Jornada
    match /seasons/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // =====================
    // Ranking
    // =====================
    match /userStats/{uid} {
      allow read: if signedIn();

      allow create, update: if (isOwner(uid) || isAdmin())
        && request.resource.data.userId == uid
        && request.resource.data.role is string
        && isRole(request.resource.data.role)
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.totalXp is int
        && request.resource.data.totalXp >= 0
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && (
          !('lastAnswerDateKey' in request.resource.data)
          || isValidDateKey(request.resource.data.lastAnswerDateKey)
        )
        && isTimestampOrIsoString(request.resource.data.updatedAt);

      allow delete: if false;
    }

    // =====================
    // Users + respostas
    // =====================
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Criação inicial do próprio perfil
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'role'])
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.role == 'player';

      // Dono só edita perfil básico; admin pode editar tudo
      allow update: if (isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL'])
          && request.resource.data.keys().hasOnly(resource.data.keys()))
        || isAdmin();

      allow delete: if false;

      match /answers/{missionId} {
        allow read: if isOwner(uid) || isAdmin();

        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['missionId', 'dateKey', 'selectedIndex', 'comment', 'createdAt'])
          && request.resource.data.missionId == missionId
          && isValidDateKey(request.resource.data.dateKey)
          && request.resource.data.selectedIndex is int
          && request.resource.data.selectedIndex >= 0
          && request.resource.data.selectedIndex <= 3
          && validCommentOrMissing(request.resource.data)
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment'])
          && validCommentOrMissing(request.resource.data);

        allow delete: if false;
      }

      match /answersByDate/{dateKey} {
        allow read: if isOwner(uid) || isAdmin();

        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['dateKey', 'missionId', 'selectedIndex', 'comment', 'createdAt'])
          && request.resource.data.dateKey == dateKey
          && isValidDateKey(request.resource.data.dateKey)
          && request.resource.data.missionId is string
          && request.resource.data.selectedIndex is int
          && request.resource.data.selectedIndex >= 0
          && request.resource.data.selectedIndex <= 3
          && validCommentOrMissing(request.resource.data)
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment'])
          && validCommentOrMissing(request.resource.data);

        allow delete: if false;
      }
    }

    // Bloqueio global
    match /answers/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
