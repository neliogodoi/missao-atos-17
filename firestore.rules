rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isRole(value) {
      return value in ['admin', 'player'];
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && request.auth.uid == 'NCypyhtWyKfR71Iws1phDOa0eVi2';
    }

    function isValidDateKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isTimestampOrIsoString(value) {
      return value is timestamp
        || (value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}T.*$'));
    }

    function validCommentOrMissing(data) {
      return !('comment' in data)
        || (data.comment is string && data.comment.size() >= 50);
    }

    // =====================
    // Public read game data
    // =====================
    match /dailyMissions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /storyEpisodes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gameConfig/rules {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ato (seasons) - necessário para Jornada
    match /seasons/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // =====================
    // Ranking
    // =====================
    match /userStats/{uid} {
      allow read: if signedIn();

      allow create, update: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'userId',
          'role',
          'displayName',
          'photoURL',
          'totalXp',
          'streak',
          'lastAnswerDateKey',
          'updatedAt'
        ])
        && request.resource.data.userId == uid
        && request.resource.data.role is string
        && isRole(request.resource.data.role)
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.totalXp is int
        && request.resource.data.totalXp >= 0
        && request.resource.data.streak is int
        && request.resource.data.streak >= 0
        && (
          !('lastAnswerDateKey' in request.resource.data)
          || isValidDateKey(request.resource.data.lastAnswerDateKey)
        )
        && request.resource.data.updatedAt is timestamp;

      allow delete: if false;
    }

    // =====================
    // Users + respostas
    // =====================
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // Criação inicial do próprio perfil
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'role'])
        && request.resource.data.displayName is string
        && request.resource.data.photoURL is string
        && request.resource.data.role == 'player';

      // Dono só edita perfil básico; admin pode editar tudo
      allow update: if (isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL'])
          && request.resource.data.keys().hasOnly(resource.data.keys()))
        || isAdmin();

      allow delete: if false;

      match /answers/{missionId} {
        allow read: if isOwner(uid) || isAdmin();

        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['missionId', 'dateKey', 'selectedIndex', 'comment', 'createdAt'])
          && request.resource.data.missionId == missionId
          && isValidDateKey(request.resource.data.dateKey)
          && request.resource.data.selectedIndex is int
          && request.resource.data.selectedIndex >= 0
          && request.resource.data.selectedIndex <= 3
          && validCommentOrMissing(request.resource.data)
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment'])
          && validCommentOrMissing(request.resource.data);

        allow delete: if false;
      }

      match /answersByDate/{dateKey} {
        allow read: if isOwner(uid) || isAdmin();

        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['dateKey', 'missionId', 'selectedIndex', 'comment', 'createdAt'])
          && request.resource.data.dateKey == dateKey
          && isValidDateKey(request.resource.data.dateKey)
          && request.resource.data.missionId is string
          && request.resource.data.selectedIndex is int
          && request.resource.data.selectedIndex >= 0
          && request.resource.data.selectedIndex <= 3
          && validCommentOrMissing(request.resource.data)
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment'])
          && validCommentOrMissing(request.resource.data);

        allow delete: if false;
      }
    }

    // =====================
    // Orações entre usuários
    // =====================
    match /prayers/{docId} {
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'senderUid',
          'recipientUid',
          'anonymous',
          'message',
          'createdAt'
        ])
        && request.resource.data.senderUid is string
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.recipientUid is string
        && request.resource.data.recipientUid.size() > 0
        && request.resource.data.recipientUid.size() <= 128
        && request.resource.data.recipientUid != request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.resource.data.recipientUid))
        && request.resource.data.anonymous is bool
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 1000
        && isTimestampOrIsoString(request.resource.data.createdAt);

      allow read: if signedIn()
        && (
          resource.data.senderUid == request.auth.uid
          || resource.data.recipientUid == request.auth.uid
          || isAdmin()
        );

      allow update, delete: if false;
    }

    // =====================
    // Retro access grants
    // =====================
    match /retroAccess/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'uid',
          'enabled',
          'allowAllRetro',
          'allowedDateKeys',
          'note',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.enabled is bool
        && request.resource.data.allowAllRetro is bool
        && (
          !('allowedDateKeys' in request.resource.data)
          || request.resource.data.allowedDateKeys == null
          || (
            request.resource.data.allowedDateKeys is list
            && request.resource.data.allowedDateKeys.size() <= 366
          )
        )
        && (
          !('note' in request.resource.data)
          || request.resource.data.note == null
          || (
            request.resource.data.note is string
            && request.resource.data.note.size() <= 240
          )
        )
        && isTimestampOrIsoString(request.resource.data.createdAt)
        && isTimestampOrIsoString(request.resource.data.updatedAt);

      allow delete: if false;
    }

    // =====================
    // Client auth logs
    // =====================
    match /authClientLogs/{logId} {
      allow create: if request.resource.data.keys().hasOnly([
          'context',
          'errorCode',
          'errorMessage',
          'host',
          'path',
          'userAgent',
          'language',
          'authUid',
          'createdAt'
        ])
        && request.resource.data.context in [
          'google-login',
          'google-login-redirect',
          'post-auth-redirect',
          'email-login',
          'email-register'
        ]
        && request.resource.data.errorCode is string
        && request.resource.data.errorCode.size() > 0
        && request.resource.data.errorCode.size() <= 120
        && request.resource.data.errorMessage is string
        && request.resource.data.errorMessage.size() > 0
        && request.resource.data.errorMessage.size() <= 500
        && request.resource.data.host is string
        && request.resource.data.host.size() <= 255
        && request.resource.data.path is string
        && request.resource.data.path.size() <= 255
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 500
        && request.resource.data.language is string
        && request.resource.data.language.size() <= 32
        && request.resource.data.authUid is string
        && request.resource.data.authUid.size() <= 128
        && request.resource.data.createdAt is timestamp;

      allow read, update, delete: if false;
    }

    // Bloqueio global
    match /answers/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
